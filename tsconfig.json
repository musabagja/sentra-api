{
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2023",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "moduleResolution": "node",
    "esModuleInterop": true,

    "sourceMap": false,
    "declaration": false,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
