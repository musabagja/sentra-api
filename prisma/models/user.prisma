
model User {
  id         Int      @id @default(autoincrement())
  name       String
  code       String   @unique
  phone      String?
  imageURL   String?
  password   String?
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  circleCode String

  circle                   Circle                    @relation(fields: [circleCode], references: [code], onUpdate: NoAction, onDelete: NoAction)
  permissions              Permission[]
  sessions                 Session[]
  uploadBatches            UploadBatch[]
  merges                   Merge[]
  mergeAdditionals         MergeAdditional[]
  cardMovements            CardMovement[]
  numberMovements          NumberMovement[]
  distributions            Distribution[]
  distributionSubmittances DistributionSubmittance[]
  opnames                  Opname[]
  opnameUpdates            OpnameUpdate[]
  opnameSubmittances       OpnameSubmittance[]
}

model Access {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  code        String   @unique
  createdAt   DateTime @default(now())

  permissions Permission[]
}

model Permission {
  id         Int      @id @default(autoincrement())
  userCode   String
  accessCode String
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userCode], references: [code], onUpdate: NoAction, onDelete: NoAction)
  access Access @relation(fields: [accessCode], references: [code], onUpdate: NoAction, onDelete: NoAction)

  @@unique([userCode, accessCode])
}

model Session {
  id        String   @id @default(uuid())
  userCode  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userCode], references: [code], onUpdate: NoAction, onDelete: NoAction)

  @@index([userCode])
}

model Circle {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  users             User[]
  checkpointCircles CheckpointCircle[]
}

model CheckpointCircle {
  id             Int      @id @default(autoincrement())
  checkpointCode String
  circleCode     String
  createdAt      DateTime @default(now())

  checkpoint Checkpoint @relation(fields: [checkpointCode], references: [code], onUpdate: NoAction, onDelete: NoAction)
  circle     Circle     @relation(fields: [circleCode], references: [code], onUpdate: NoAction, onDelete: NoAction)

  @@unique([checkpointCode, circleCode])
}
